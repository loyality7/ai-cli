.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
#   For a library or app, you might want to share your .python-version.
#   For an executable, it's sometimes better to keep it out of git.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in git.
#   However, in case of collaboration, if the system default python differs from yours,
#   you may want to bypass Pipfile.lock.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock contains the resolved dependencies,
#   and is recommended to be committed.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock contains the resolved dependencies,
#   and is recommended to be committed.
#.pdm-python.plugins
#pdm.lock
#pdm.toml

# PEP 582; used by e.g. github.com/lincolnloop/layman and pdm
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

